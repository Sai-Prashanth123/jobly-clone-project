generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId          String    @unique @default(dbgenerated("generate_display_id('EMP-', 'employee_seq')")) @db.Text @map("display_id")
  firstName          String    @db.Text          @map("first_name")
  lastName           String    @db.Text          @map("last_name")
  email              String    @unique @db.Text
  phone              String    @default("")      @db.Text
  dob                DateTime? @db.Date
  addressStreet      String    @default("")      @db.Text @map("address_street")
  addressCity        String    @default("")      @db.Text @map("address_city")
  addressState       String    @default("")      @db.Text @map("address_state")
  addressZip         String    @default("")      @db.Text @map("address_zip")
  addressCountry     String    @default("US")    @db.Text @map("address_country")
  department         String    @db.Text
  jobTitle           String    @db.Text          @map("job_title")
  employmentType     String    @db.Text          @map("employment_type")
  startDate          DateTime  @db.Date          @map("start_date")
  managerId          String?   @db.Uuid          @map("manager_id")
  status             String    @default("onboarding") @db.Text
  visaType           String?   @db.Text          @map("visa_type")
  visaExpiry         DateTime? @db.Date          @map("visa_expiry")
  i9Status           String?   @db.Text          @map("i9_status")
  payRate            Decimal   @default(0)       @db.Decimal(10, 2) @map("pay_rate")
  payType            String    @default("hourly") @db.Text @map("pay_type")
  payFrequency       String    @default("biweekly") @db.Text @map("pay_frequency")
  workLocation       String?   @db.Text          @map("work_location")
  ssn                String?   @db.Text
  paymentType        String?   @db.Text          @map("payment_type")
  bankName           String?   @db.Text          @map("bank_name")
  bankRoutingNumber  String?   @db.Text          @map("bank_routing_number")
  bankAccountNumber  String?   @db.Text          @map("bank_account_number")
  taxFormType        String?   @db.Text          @map("tax_form_type")
  reportingManagerId String?   @db.Uuid          @map("reporting_manager_id")
  deletedAt          DateTime? @db.Timestamptz(3) @map("deleted_at")
  createdAt          DateTime  @default(now())   @db.Timestamptz(3) @map("created_at")
  updatedAt          DateTime  @default(now())   @db.Timestamptz(3) @map("updated_at")

  timesheets  Timesheet[]
  assignments Assignment[]

  @@map("employees")
}

model Client {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId           String    @unique @db.Text  @map("display_id")
  companyName         String    @db.Text          @map("company_name")
  contactName         String    @db.Text          @map("contact_name")
  contactEmail        String    @db.Text          @map("contact_email")
  contactPhone        String?   @db.Text          @map("contact_phone")
  industry            String    @default("")      @db.Text
  addressStreet       String    @default("")      @db.Text @map("address_street")
  addressCity         String    @default("")      @db.Text @map("address_city")
  addressState        String    @default("")      @db.Text @map("address_state")
  addressZip          String    @default("")      @db.Text @map("address_zip")
  addressCountry      String    @default("US")    @db.Text @map("address_country")
  contractStartDate   DateTime  @db.Date          @map("contract_start_date")
  contractEndDate     DateTime? @db.Date          @map("contract_end_date")
  netPaymentDays      Int       @default(30)      @map("net_payment_days")
  defaultBillRate     Decimal   @default(0)       @db.Decimal(10, 2) @map("default_bill_rate")
  currency            String    @default("USD")   @db.Text
  billingType         String?   @db.Text          @map("billing_type")
  billingContactName  String?   @db.Text          @map("billing_contact_name")
  billingContactEmail String?   @db.Text          @map("billing_contact_email")
  billingContactPhone String?   @db.Text          @map("billing_contact_phone")
  billingStreet       String?   @db.Text          @map("billing_street")
  billingCity         String?   @db.Text          @map("billing_city")
  billingState        String?   @db.Text          @map("billing_state")
  billingZip          String?   @db.Text          @map("billing_zip")
  billingCountry      String?   @db.Text          @map("billing_country")
  taxId               String?   @db.Text          @map("tax_id")
  status              String    @default("active") @db.Text
  deletedAt           DateTime? @db.Timestamptz(3) @map("deleted_at")
  createdAt           DateTime  @default(now())   @db.Timestamptz(3) @map("created_at")
  updatedAt           DateTime  @default(now())   @db.Timestamptz(3) @map("updated_at")

  timesheets  Timesheet[]
  assignments Assignment[]
  invoices    Invoice[]

  @@map("clients")
}

model Assignment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId        String    @unique @db.Text  @map("display_id")
  employeeId       String    @db.Uuid          @map("employee_id")
  clientId         String    @db.Uuid          @map("client_id")
  projectName      String    @db.Text          @map("project_name")
  role             String    @db.Text
  startDate        DateTime  @db.Date          @map("start_date")
  endDate          DateTime? @db.Date          @map("end_date")
  billRate         Decimal   @default(0)       @db.Decimal(10, 2) @map("bill_rate")
  payRate          Decimal   @default(0)       @db.Decimal(10, 2) @map("pay_rate")
  maxHoursPerWeek  Int       @default(40)      @map("max_hours_per_week")
  status           String    @default("pending") @db.Text
  billingType      String?   @db.Text          @map("billing_type")
  workLocation     String?   @db.Text          @map("work_location")
  reportingManagerId String? @db.Uuid          @map("reporting_manager_id")
  createdAt        DateTime  @default(now())   @db.Timestamptz(3) @map("created_at")
  updatedAt        DateTime  @default(now())   @db.Timestamptz(3) @map("updated_at")

  employee   Employee    @relation(fields: [employeeId], references: [id])
  client     Client      @relation(fields: [clientId], references: [id])
  timesheets Timesheet[]

  @@map("assignments")
}

model Timesheet {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayId        String    @unique @db.Text  @map("display_id")
  employeeId       String    @db.Uuid          @map("employee_id")
  assignmentId     String    @db.Uuid          @map("assignment_id")
  clientId         String    @db.Uuid          @map("client_id")
  weekStartDate    DateTime  @db.Date          @map("week_start_date")
  weekEndDate      DateTime  @db.Date          @map("week_end_date")
  totalHours       Decimal   @default(0)       @db.Decimal(6, 2) @map("total_hours")
  status           String    @default("draft") @db.Text
  notes            String?   @db.Text
  submittedAt      DateTime? @db.Timestamptz(3) @map("submitted_at")
  managerApprovedAt DateTime? @db.Timestamptz(3) @map("manager_approved_at")
  clientApprovedAt  DateTime? @db.Timestamptz(3) @map("client_approved_at")
  rejectionReason  String?   @db.Text          @map("rejection_reason")
  createdAt        DateTime  @default(now())   @db.Timestamptz(3) @map("created_at")
  updatedAt        DateTime  @default(now())   @db.Timestamptz(3) @map("updated_at")

  employee   Employee         @relation(fields: [employeeId], references: [id])
  assignment Assignment       @relation(fields: [assignmentId], references: [id])
  client     Client           @relation(fields: [clientId], references: [id])
  entries    TimesheetEntry[]

  @@unique([employeeId, assignmentId, weekStartDate])
  @@map("timesheets")
}

model TimesheetEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timesheetId String   @db.Uuid  @map("timesheet_id")
  entryDate   DateTime @db.Date  @map("entry_date")
  dayOfWeek   String   @db.Text  @map("day_of_week")
  hours       Decimal  @default(0) @db.Decimal(4, 2)
  isBillable  Boolean  @default(true) @map("is_billable")

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@unique([timesheetId, entryDate])
  @@map("timesheet_entries")
}

model Invoice {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber String    @unique @db.Text  @map("invoice_number")
  clientId      String    @db.Uuid          @map("client_id")
  issueDate     DateTime  @db.Date          @map("issue_date")
  dueDate       DateTime  @db.Date          @map("due_date")
  subtotal      Decimal   @default(0)       @db.Decimal(12, 2)
  taxRate       Decimal   @default(0)       @db.Decimal(5, 2) @map("tax_rate")
  taxAmount     Decimal   @default(0)       @db.Decimal(12, 2) @map("tax_amount")
  totalAmount   Decimal   @default(0)       @db.Decimal(12, 2) @map("total_amount")
  status        String    @default("draft") @db.Text
  pdfUrl        String?   @db.Text          @map("pdf_url")
  paidAt        DateTime? @db.Timestamptz(3) @map("paid_at")
  notes         String?   @db.Text
  billingPeriodStart DateTime? @db.Date     @map("billing_period_start")
  billingPeriodEnd   DateTime? @db.Date     @map("billing_period_end")
  createdAt     DateTime  @default(now())   @db.Timestamptz(3) @map("created_at")
  updatedAt     DateTime  @default(now())   @db.Timestamptz(3) @map("updated_at")

  client    Client            @relation(fields: [clientId], references: [id])
  lineItems InvoiceLineItem[]

  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String  @db.Uuid @map("invoice_id")
  timesheetId String? @db.Uuid @map("timesheet_id")
  employeeId  String? @db.Uuid @map("employee_id")
  description String  @db.Text
  hours       Decimal @default(0) @db.Decimal(6, 2)
  billRate    Decimal @default(0) @db.Decimal(10, 2) @map("bill_rate")
  amount      Decimal @default(0) @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model Document {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  String   @db.Text  @map("entity_type")
  entityId    String   @db.Uuid  @map("entity_id")
  name        String   @db.Text
  type        String   @db.Text
  storagePath String   @db.Text  @map("storage_path")
  storageUrl  String?  @db.Text  @map("storage_url")
  uploadedBy  String?  @db.Uuid  @map("uploaded_by")
  uploadedAt  DateTime @default(now()) @db.Timestamptz(3) @map("uploaded_at")

  // Polymorphic: entityId can reference employees or clients — no Prisma relation
  @@map("documents")
}
